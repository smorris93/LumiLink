<?xml version="1.0" encoding="utf-8"?>
<!--
  The camera speaks plain HTTP (no TLS) at 192.168.54.1 — cam.cgi control, the UPnP device
  description (:60606), and the file server (:50001). Android blocks cleartext by default since
  API 28, so we permit it ONLY for the camera's fixed address, keeping the rest of the app secure.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.54.1</domain>
    </domain-config>
</network-security-config>
